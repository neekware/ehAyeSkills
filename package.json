{
  "name": "ehaye-skills",
  "version": "1.0.0",
  "private": true,
  "description": "Curated, validated skill repository for ehAye Dojo",
  "scripts": {
    "curate": "node scripts/curate.cjs",
    "curate:check": "node scripts/curate.cjs --check",
    "curate:local": "node scripts/curate.cjs --no-push",
    "bundle:export": "node scripts/export-bundle.cjs",
    "bundle:clean": "node -e \"require('fs').rmSync('artifacts/bundle',{recursive:true,force:true})\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "format": "prettier --write '**/*.md'",
    "format:check": "prettier --check '**/*.md'"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}
