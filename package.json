{
  "name": "ehaye-skills",
  "version": "1.0.0",
  "private": true,
  "description": "Curated, validated skill repository for ehAye Dojo",
  "scripts": {
    "curate": "node scripts/curate.cjs",
    "curate:check": "node scripts/curate.cjs --check",
    "curate:local": "node scripts/curate.cjs --no-push",
    "format": "prettier --write '**/*.md'",
    "format:check": "prettier --check '**/*.md'"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "license": "MIT"
}
